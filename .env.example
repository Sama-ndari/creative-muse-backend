# OpenRouter API key — get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxx

# OpenAI API key — required for /api/get-muse-premium
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxx

# Client key sent in X-Premium-Key header — required for /api/get-muse-premium and /api/me-chat
PREMIUM_API_KEY=your-secret-premium-key

# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o

# Optional — comma-separated allowlist for client model override
OPENAI_ALLOWED_MODELS=gpt-4o-mini,gpt-4o,gpt-4.1-mini,gpt-4.1

